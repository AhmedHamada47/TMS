@model ChangePasswordViewModel
@{
    ViewData["Title"] = "Change Password";
}

<div class="card" style="max-width: 500px;">
    <div class="card-header">
        <i class="fas fa-key me-2"></i>Change Password
    </div>
    <div class="card-body">
        <form asp-action="ChangePassword" method="post">
            <div class="row g-4">
                <div class="col-12">
                    <label asp-for="CurrentPassword" class="form-label"></label>
                    <input asp-for="CurrentPassword" class="form-control" />
                    <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label asp-for="NewPassword" class="form-label">New Password</label>
                    <input asp-for="NewPassword" class="form-control" />
                    <span asp-validation-for="NewPassword" class="text-danger small"></span>
                    <div class="form-text">At least 8 characters, one letter, and one number required.</div>
                </div>
                <div class="col-12">
                    <label asp-for="ConfirmPassword" class="form-label">Confirm New Password</label>
                    <input asp-for="ConfirmPassword" class="form-control" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>
                <div class="col-12 d-flex gap-2 justify-content-end">
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save me-1"></i> Change Password
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
