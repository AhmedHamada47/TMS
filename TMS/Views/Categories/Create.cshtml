@model Category
@{
    ViewData["Title"] = "Create Category";
}

<div class="card" style="max-width: 600px;">
    <div class="card-header">
        <i class="fas fa-folder-plus me-2"></i>New Category
    </div>
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div class="row g-4">
                <div class="col-12">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control" placeholder="e.g., Development, Design..." />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label asp-for="Description" class="form-label"></label>
                    <textarea asp-for="Description" class="form-control" placeholder="Brief description of this category..." rows="3"></textarea>
                </div>
                <div class="col-md-6">
                    <label asp-for="Color" class="form-label">Color</label>
                    <div class="d-flex gap-2 align-items-center">
                        <input asp-for="Color" type="color" class="form-control form-control-color" style="width: 60px; padding: 4px;" />
                        <input asp-for="Color" class="form-control" id="colorText" />
                    </div>
                </div>
                <div class="col-12 d-flex gap-2 justify-content-end">
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save me-1"></i> Create
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.querySelector('input[type="color"]')?.addEventListener('input', function() {
            document.getElementById('colorText').value = this.value;
        });
        document.getElementById('colorText')?.addEventListener('input', function() {
            document.querySelector('input[type="color"]').value = this.value;
        });
    </script>
}
