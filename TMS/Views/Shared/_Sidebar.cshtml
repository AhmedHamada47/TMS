@inject TMS.Data.AppDbContext _context
@using System.Security.Claims
@using Microsoft.EntityFrameworkCore
@{
    var categoryCounts = _context.Categories.Select(c => new { c.Id, c.Name, c.Color, Count = c.Tasks.Count }).AsNoTracking().ToList();
    var userId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    var userName = User.FindFirstValue(ClaimTypes.Name) ?? "User";
    var userEmail = User.FindFirstValue(ClaimTypes.Email) ?? "";
    var dbUser = userId != null ? _context.Users.AsNoTracking().FirstOrDefault(u => u.Id == int.Parse(userId)) : null;
    var avatarUrl = dbUser?.AvatarUrl ?? "https://pub-a981f7fafe3c46e98d60519aae806cf8.r2.dev/Avatar/Male/Number_21_b9m4ba_elzprp.png";
}
<aside class="sidebar">
    <div class="sidebar-header">
        <a asp-controller="Home" asp-action="Index" class="sidebar-logo text-decoration-none">
            <i class="fas fa-tasks"></i>
            <span>TaskFlow</span>
        </a>
    </div>
    <nav class="sidebar-nav">
        <ul class="nav-list">
            <li class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "active" : "")">
                <a asp-controller="Home" asp-action="Index" class="nav-link">
                    <i class="fas fa-chart-pie"></i>
                    <span>Dashboard</span>
                </a>
            </li>
            <li class="nav-section">Management</li>
            <li class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Tasks" ? "active" : "")">
                <a asp-controller="Tasks" asp-action="Index" class="nav-link">
                    <i class="fas fa-list-check"></i>
                    <span>All Tasks</span>
                </a>
            </li>
            <li class="nav-item">
                <a asp-controller="Tasks" asp-action="Create" class="nav-link">
                    <i class="fas fa-plus-circle"></i>
                    <span>New Task</span>
                </a>
            </li>
            <li class="nav-section">Categories</li>
            @foreach (var cat in categoryCounts)
            {
                <li class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Categories" && Context.Request.Query["categoryId"].ToString() == cat.Id.ToString() ? "active" : "")">
                    <a asp-controller="Tasks" asp-action="Index" asp-route-categoryId="@cat.Id" class="nav-link">
                        <span class="category-dot" style="background: @cat.Color"></span>
                        <span>@cat.Name</span>
                        <span class="badge">@cat.Count</span>
                    </a>
                </li>
            }
            <li class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Categories" && ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")">
                <a asp-controller="Categories" asp-action="Index" class="nav-link">
                    <i class="fas fa-gear"></i>
                    <span>Manage Categories</span>
                </a>
            </li>
            <li class="nav-section">Account</li>
            <li class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Profile" ? "active" : "")">
                <a asp-controller="Profile" asp-action="Index" class="nav-link">
                    <i class="fas fa-user"></i>
                    <span>My Profile</span>
                </a>
            </li>
            <li class="nav-item">
                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                    <button type="submit" class="nav-link" style="border: none; background: none; width: 100%; cursor: pointer;">
                        <i class="fas fa-sign-out-alt"></i>
                        <span>Logout</span>
                    </button>
                </form>
            </li>
        </ul>
    </nav>
    <div class="sidebar-footer">
        <a asp-controller="Profile" asp-action="Index" class="text-decoration-none">
            <div class="user-info">
                <img src="@avatarUrl" alt="" class="user-avatar" />
                <div class="user-details">
                    <span class="user-name">@userName</span>
                    <span class="user-role">@userEmail</span>
                </div>
            </div>
        </a>
    </div>
</aside>
