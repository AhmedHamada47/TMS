@model SidebarViewModel

<aside class="sidebar">
    <div class="sidebar-header">
        <a asp-controller="Home" asp-action="Index" class="sidebar-logo text-decoration-none">
            <i class="fas fa-tasks"></i>
            <span>TaskFlow</span>
        </a>
    </div>
    <nav class="sidebar-nav">
        <ul class="nav-list">
            <li class="nav-item @(Model.CurrentController == "Home" ? "active" : "")">
                <a asp-controller="Home" asp-action="Index" class="nav-link">
                    <i class="fas fa-chart-pie"></i>
                    <span>Dashboard</span>
                </a>
            </li>
            <li class="nav-section">Management</li>
            <li class="nav-item @(Model.CurrentController == "Tasks" ? "active" : "")">
                <a asp-controller="Tasks" asp-action="Index" class="nav-link">
                    <i class="fas fa-list-check"></i>
                    <span>All Tasks</span>
                </a>
            </li>
            <li class="nav-item">
                <a asp-controller="Tasks" asp-action="Create" class="nav-link">
                    <i class="fas fa-plus-circle"></i>
                    <span>New Task</span>
                </a>
            </li>
            <li class="nav-section">Categories</li>
            @foreach (var cat in Model.Categories)
            {
                <li class="nav-item @(Model.CurrentController == "Categories" && Model.CurrentCategoryId == cat.Id.ToString() ? "active" : "")">
                    <a asp-controller="Tasks" asp-action="Index" asp-route-categoryId="@cat.Id" class="nav-link">
                        <span class="category-dot" style="background: @cat.Color"></span>
                        <span>@cat.Name</span>
                        <span class="badge">@cat.TaskCount</span>
                    </a>
                </li>
            }
            <li class="nav-item @(Model.CurrentController == "Categories" && Model.CurrentAction == "Index" ? "active" : "")">
                <a asp-controller="Categories" asp-action="Index" class="nav-link">
                    <i class="fas fa-gear"></i>
                    <span>Manage Categories</span>
                </a>
            </li>
            <li class="nav-section">Account</li>
            <li class="nav-item @(Model.CurrentController == "Profile" ? "active" : "")">
                <a asp-controller="Profile" asp-action="Index" class="nav-link">
                    <i class="fas fa-user"></i>
                    <span>My Profile</span>
                </a>
            </li>
            <li class="nav-item">
                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                    <button type="submit" class="nav-link" style="border: none; background: none; width: 100%; cursor: pointer;">
                        <i class="fas fa-sign-out-alt"></i>
                        <span>Logout</span>
                    </button>
                </form>
            </li>
        </ul>
    </nav>
    <div class="sidebar-footer">
        <a asp-controller="Profile" asp-action="Index" class="text-decoration-none">
            <div class="user-info">
                <img src="@Model.AvatarUrl" alt="" class="user-avatar" />
                <div class="user-details">
                    <span class="user-name">@Model.UserName</span>
                    <span class="user-role">@Model.UserEmail</span>
                </div>
            </div>
        </a>
    </div>
</aside>
