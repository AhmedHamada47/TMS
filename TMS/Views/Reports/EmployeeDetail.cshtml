@model List<TaskItem>
@{
    ViewData["Title"] = $"{ViewBag.EmployeeName} — Tasks";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <div class="d-flex align-items-center gap-3">
            <img src="@ViewBag.AvatarUrl" alt="" class="user-avatar-sm" style="width: 40px; height: 40px;" />
            <div>
                <h5 class="fw-bold mb-0"><i class="fas fa-user me-2"></i>@ViewBag.EmployeeName</h5>
                <small class="text-muted">@Model.Count task(s)</small>
            </div>
        </div>
    </div>
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
        <i class="fas fa-arrow-left me-1"></i> Back to Report
    </a>
</div>

<div class="card">
    <div class="card-header"><i class="fas fa-list me-2"></i>All Tasks</div>
    <div class="card-body p-0">
        <div class="table-container" style="box-shadow: none;">
            <table class="table">
                <thead>
                    <tr>
                        <th>Task</th>
                        <th>Status</th>
                        <th>Priority</th>
                        <th>Category</th>
                        <th>Due Date</th>
                        <th>Est / Actual</th>
                        <th>Assigned To</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7">
                                <div class="empty-state">
                                    <i class="fas fa-inbox"></i>
                                    <h5>No tasks</h5>
                                </div>
                            </td>
                        </tr>
                    }
                    @foreach (var task in Model)
                    {
                        <tr>
                            <td>
                                <a asp-controller="Tasks" asp-action="Details" asp-route-id="@task.Id" class="fw-semibold text-decoration-none">
                                    @task.Title
                                </a>
                            </td>
                            <td>
                                <span class="status-badge status-@(task.Status == TaskItemStatus.ToDo ? "todo" : task.Status == TaskItemStatus.InProgress ? "progress" : "done")">
                                    <span class="status-dot"></span>
                                    @(task.Status == TaskItemStatus.InProgress ? "In Progress" : task.Status.ToString())
                                </span>
                            </td>
                            <td>
                                <span class="priority-badge priority-@task.Priority.ToString().ToLower()">
                                    @(task.Priority == TaskPriority.Urgent ? "Urgent" : task.Priority.ToString())
                                </span>
                            </td>
                            <td>
                                @if (task.Category != null)
                                {
                                    <span class="category-tag">
                                        <span class="cat-dot" style="background: @task.Category.Color"></span>
                                        @task.Category.Name
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td class="text-nowrap">
                                @if (task.DueDate.HasValue)
                                {
                                    <span class="@(task.DueDate.Value.Date < DateTime.UtcNow.Date && task.Status != TaskItemStatus.Done ? "text-danger fw-semibold" : "")">
                                        @task.DueDate.Value.ToString("MMM dd, yyyy")
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td>
                                @if (task.EstimatedHours.HasValue)
                                {
                                    <span>@task.EstimatedHours.Value h</span>
                                    @if (task.ActualHours.HasValue)
                                    {
                                        <span class="text-muted"> / @task.ActualHours.Value h</span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td>
                                @{
                                    var assignee = task.Assignees?.FirstOrDefault(a => a.IsPrimary)?.User;
                                }
                                @if (assignee != null)
                                {
                                    <div class="user-cell">
                                        <img src="@assignee.AvatarUrl" alt="" class="user-avatar-sm" />
                                        <span>@assignee.Name</span>
                                    </div>
                                }
                                else
                                {
                                    <span class="text-muted">Unassigned</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
